<?xml version="1.0"?>
<rdf:RDF
    xmlns="http://example.org/cubesat-ontology#"
    xml:base="http://example.org/cubesat-ontology"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#">

  <owl:Ontology rdf:about="http://example.org/cubesat-ontology">
    <rdfs:comment>Minimal CubeSat ontology with subsystems, components, object properties, and datatype properties.</rdfs:comment>
  </owl:Ontology>

  <!-- ===================== -->
  <!-- Classes               -->
  <!-- ===================== -->

  <owl:Class rdf:about="#SpaceSystem"/>
  <owl:Class rdf:about="#CubeSat">
    <rdfs:subClassOf rdf:resource="#SpaceSystem"/>
  </owl:Class>

  <owl:Class rdf:about="#Subsystem"/>
  <owl:Class rdf:about="#Component"/>

  <!-- Subsystem specializations -->
  <owl:Class rdf:about="#PowerSubsystem">
    <rdfs:subClassOf rdf:resource="#Subsystem"/>
  </owl:Class>
  <owl:Class rdf:about="#ADCSSubsystem">
    <rdfs:subClassOf rdf:resource="#Subsystem"/>
  </owl:Class>
  <owl:Class rdf:about="#CommunicationSubsystem">
    <rdfs:subClassOf rdf:resource="#Subsystem"/>
  </owl:Class>
  <owl:Class rdf:about="#CommandAndDataHandlingSubsystem">
    <rdfs:subClassOf rdf:resource="#Subsystem"/>
  </owl:Class>
  <owl:Class rdf:about="#ThermalSubsystem">
    <rdfs:subClassOf rdf:resource="#Subsystem"/>
  </owl:Class>
  <owl:Class rdf:about="#StructureSubsystem">
    <rdfs:subClassOf rdf:resource="#Subsystem"/>
  </owl:Class>
  <owl:Class rdf:about="#PayloadSubsystem">
    <rdfs:subClassOf rdf:resource="#Subsystem"/>
  </owl:Class>

  <!-- Component specializations -->
  <owl:Class rdf:about="#SolarPanel">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>
  <owl:Class rdf:about="#Battery">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>
  <owl:Class rdf:about="#PowerDistributionUnit">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>
  <owl:Class rdf:about="#ReactionWheel">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>
  <owl:Class rdf:about="#Magnetorquer">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>
  <owl:Class rdf:about="#StarTracker">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>
  <owl:Class rdf:about="#IMU">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>
  <owl:Class rdf:about="#Radio">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>
  <owl:Class rdf:about="#Antenna">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>
  <owl:Class rdf:about="#OnBoardComputer">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>
  <owl:Class rdf:about="#FlightSoftware">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>
  <owl:Class rdf:about="#PayloadInstrument">
    <rdfs:subClassOf rdf:resource="#Component"/>
  </owl:Class>

  <!-- Support classes -->
  <owl:Class rdf:about="#BusProtocol"/>
  <owl:Class rdf:about="#Interface"/>
  <owl:Class rdf:about="#Requirement"/>

  <!-- ===================== -->
  <!-- Object Properties     -->
  <!-- ===================== -->

  <!-- CubeSat composition -->
  <owl:ObjectProperty rdf:about="#hasSubsystem">
    <rdfs:domain rdf:resource="#CubeSat"/>
    <rdfs:range rdf:resource="#Subsystem"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasComponent">
    <rdfs:domain rdf:resource="#Subsystem"/>
    <rdfs:range rdf:resource="#Component"/>
  </owl:ObjectProperty>

  <!-- Part-of relations (transitive) -->
  <owl:ObjectProperty rdf:about="#partOf">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:domain rdf:resource="#SpaceSystem"/>
    <rdfs:range rdf:resource="#SpaceSystem"/>
  </owl:ObjectProperty>

  <!-- Interfaces -->
  <owl:ObjectProperty rdf:about="#interfacesWith">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="#Component"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#usesBusProtocol">
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="#BusProtocol"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#hasInterface">
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="#Interface"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#satisfiesRequirement">
    <rdfs:domain rdf:resource="#SpaceSystem"/>
    <rdfs:range rdf:resource="#Requirement"/>
  </owl:ObjectProperty>

  <!-- Helpful inverse properties -->
  <owl:ObjectProperty rdf:about="#subsystemOf">
    <owl:inverseOf rdf:resource="#hasSubsystem"/>
    <rdfs:domain rdf:resource="#Subsystem"/>
    <rdfs:range rdf:resource="#CubeSat"/>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="#componentOf">
    <owl:inverseOf rdf:resource="#hasComponent"/>
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="#Subsystem"/>
  </owl:ObjectProperty>

  <!-- ===================== -->
  <!-- Datatype Properties   -->
  <!-- ===================== -->

  <owl:DatatypeProperty rdf:about="#identifier">
    <rdfs:domain rdf:resource="#SpaceSystem"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#manufacturer">
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#modelName">
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#massKg">
    <rdfs:domain rdf:resource="#SpaceSystem"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#powerW">
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#voltageV">
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#dataRateMbps">
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#frequencyMHz">
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#operatingTempMinC">
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#operatingTempMaxC">
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="#heritageTRL">
    <rdfs:domain rdf:resource="#Component"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>

  <!-- ===================== -->
  <!-- Some Individuals      -->
  <!-- ===================== -->

  <!-- Bus protocols -->
  <owl:NamedIndividual rdf:about="#I2C">
    <rdf:type rdf:resource="#BusProtocol"/>
    <rdfs:label>I2C</rdfs:label>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="#SPI">
    <rdf:type rdf:resource="#BusProtocol"/>
    <rdfs:label>SPI</rdfs:label>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="#CAN">
    <rdf:type rdf:resource="#BusProtocol"/>
    <rdfs:label>CAN</rdfs:label>
  </owl:NamedIndividual>
  <owl:NamedIndividual rdf:about="#UART">
    <rdf:type rdf:resource="#BusProtocol"/>
    <rdfs:label>UART</rdfs:label>
  </owl:NamedIndividual>

  <!-- Example CubeSat -->
  <owl:NamedIndividual rdf:about="#DemoCubeSat1">
    <rdf:type rdf:resource="#CubeSat"/>
    <identifier>DEMO-1</identifier>
    <massKg rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">6.0</massKg>
  </owl:NamedIndividual>

  <!-- Subsystems -->
  <owl:NamedIndividual rdf:about="#EPS1">
    <rdf:type rdf:resource="#PowerSubsystem"/>
    <identifier>EPS-1</identifier>
    <partOf rdf:resource="#DemoCubeSat1"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#ADCS1">
    <rdf:type rdf:resource="#ADCSSubsystem"/>
    <identifier>ADCS-1</identifier>
    <partOf rdf:resource="#DemoCubeSat1"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#COMMS1">
    <rdf:type rdf:resource="#CommunicationSubsystem"/>
    <identifier>COMMS-1</identifier>
    <partOf rdf:resource="#DemoCubeSat1"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#CDH1">
    <rdf:type rdf:resource="#CommandAndDataHandlingSubsystem"/>
    <identifier>CDH-1</identifier>
    <partOf rdf:resource="#DemoCubeSat1"/>
  </owl:NamedIndividual>

  <!-- Link CubeSat -> subsystems -->
  <rdf:Description rdf:about="#DemoCubeSat1">
    <hasSubsystem rdf:resource="#EPS1"/>
    <hasSubsystem rdf:resource="#ADCS1"/>
    <hasSubsystem rdf:resource="#COMMS1"/>
    <hasSubsystem rdf:resource="#CDH1"/>
  </rdf:Description>

  <!-- Components -->
  <owl:NamedIndividual rdf:about="#BatteryPack1">
    <rdf:type rdf:resource="#Battery"/>
    <identifier>BAT-1</identifier>
    <manufacturer>ExampleVendor</manufacturer>
    <modelName>BAT-2S-10Wh</modelName>
    <massKg rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.25</massKg>
    <voltageV rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">7.4</voltageV>
    <powerW rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.0</powerW>
    <operatingTempMinC rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">-10</operatingTempMinC>
    <operatingTempMaxC rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">40</operatingTempMaxC>
    <heritageTRL rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</heritageTRL>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#PDU1">
    <rdf:type rdf:resource="#PowerDistributionUnit"/>
    <identifier>PDU-1</identifier>
    <manufacturer>ExampleVendor</manufacturer>
    <modelName>PDU-5V-3V3</modelName>
    <massKg rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.18</massKg>
    <powerW rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.5</powerW>
    <voltageV rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">5.0</voltageV>
    <usesBusProtocol rdf:resource="#I2C"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#OBC1">
    <rdf:type rdf:resource="#OnBoardComputer"/>
    <identifier>OBC-1</identifier>
    <manufacturer>ExampleVendor</manufacturer>
    <modelName>OBC-A32</modelName>
    <massKg rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.12</massKg>
    <powerW rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">2.0</powerW>
    <usesBusProtocol rdf:resource="#I2C"/>
    <usesBusProtocol rdf:resource="#SPI"/>
  </owl:NamedIndividual>

  <owl:NamedIndividual rdf:about="#Radio1">
    <rdf:type rdf:resource="#Radio"/>
    <identifier>RAD-1</identifier>
    <manufacturer>ExampleVendor</manufacturer>
    <modelName>UHF-Transceiver</modelName>
    <massKg rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.20</massKg>
    <powerW rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">4.0</powerW>
    <dataRateMbps rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">0.256</dataRateMbps>
    <frequencyMHz rdf:datatype="http://www.w3.org/2001/XMLSchema#decimal">437.5</frequencyMHz>
  </owl:NamedIndividual>

  <!-- Connect components to subsystems -->
  <rdf:Description rdf:about="#EPS1">
    <hasComponent rdf:resource="#BatteryPack1"/>
    <hasComponent rdf:resource="#PDU1"/>
  </rdf:Description>

  <rdf:Description rdf:about="#CDH1">
    <hasComponent rdf:resource="#OBC1"/>
  </rdf:Description>

  <rdf:Description rdf:about="#COMMS1">
    <hasComponent rdf:resource="#Radio1"/>
  </rdf:Description>

  <!-- Example interface relationship -->
  <rdf:Description rdf:about="#OBC1">
    <interfacesWith rdf:resource="#PDU1"/>
    <interfacesWith rdf:resource="#Radio1"/>
  </rdf:Description>

</rdf:RDF>