<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/uam#"
     xml:base="http://example.org/uam"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

<owl:Ontology rdf:about="http://example.org/uam"/>

<!-- ===================== -->
<!-- CLASS HIERARCHY -->
<!-- ===================== -->

<!-- Core System -->
<owl:Class rdf:about="#System"/>
<owl:Class rdf:about="#Vehicle">
    <rdfs:subClassOf rdf:resource="#System"/>
</owl:Class>
<owl:Class rdf:about="#Aircraft">
    <rdfs:subClassOf rdf:resource="#Vehicle"/>
</owl:Class>
<owl:Class rdf:about="#eVTOL">
    <rdfs:subClassOf rdf:resource="#Aircraft"/>
</owl:Class>

<!-- Infrastructure -->
<owl:Class rdf:about="#Infrastructure"/>
<owl:Class rdf:about="#Vertiport">
    <rdfs:subClassOf rdf:resource="#Infrastructure"/>
</owl:Class>
<owl:Class rdf:about="#ChargingStation">
    <rdfs:subClassOf rdf:resource="#Infrastructure"/>
</owl:Class>

<!-- Operation -->
<owl:Class rdf:about="#Operation"/>
<owl:Class rdf:about="#Mission">
    <rdfs:subClassOf rdf:resource="#Operation"/>
</owl:Class>
<owl:Class rdf:about="#FlightOperation">
    <rdfs:subClassOf rdf:resource="#Mission"/>
</owl:Class>
<owl:Class rdf:about="#EmergencyOperation">
    <rdfs:subClassOf rdf:resource="#Mission"/>
</owl:Class>

<!-- Route -->
<owl:Class rdf:about="#Route"/>
<owl:Class rdf:about="#FlightRoute">
    <rdfs:subClassOf rdf:resource="#Route"/>
</owl:Class>

<!-- Airspace -->
<owl:Class rdf:about="#Airspace"/>
<owl:Class rdf:about="#ControlledAirspace">
    <rdfs:subClassOf rdf:resource="#Airspace"/>
</owl:Class>
<owl:Class rdf:about="#UrbanAirspace">
    <rdfs:subClassOf rdf:resource="#Airspace"/>
</owl:Class>

<!-- Actors -->
<owl:Class rdf:about="#Agent"/>
<owl:Class rdf:about="#Operator">
    <rdfs:subClassOf rdf:resource="#Agent"/>
</owl:Class>
<owl:Class rdf:about="#Passenger">
    <rdfs:subClassOf rdf:resource="#Agent"/>
</owl:Class>
<owl:Class rdf:about="#Pilot">
    <rdfs:subClassOf rdf:resource="#Agent"/>
</owl:Class>

<!-- Environment -->
<owl:Class rdf:about="#Environment"/>
<owl:Class rdf:about="#WeatherCondition">
    <rdfs:subClassOf rdf:resource="#Environment"/>
</owl:Class>

<!-- Energy -->
<owl:Class rdf:about="#EnergySystem"/>
<owl:Class rdf:about="#BatterySystem">
    <rdfs:subClassOf rdf:resource="#EnergySystem"/>
</owl:Class>

<!-- ===================== -->
<!-- OBJECT PROPERTIES -->
<!-- ===================== -->

<owl:ObjectProperty rdf:about="#operates">
    <rdfs:domain rdf:resource="#Operator"/>
    <rdfs:range rdf:resource="#Aircraft"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#assignedTo">
    <rdfs:domain rdf:resource="#Aircraft"/>
    <rdfs:range rdf:resource="#Mission"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasDeparture">
    <rdfs:domain rdf:resource="#Mission"/>
    <rdfs:range rdf:resource="#Vertiport"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasArrival">
    <rdfs:domain rdf:resource="#Mission"/>
    <rdfs:range rdf:resource="#Vertiport"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#usesRoute">
    <rdfs:domain rdf:resource="#Mission"/>
    <rdfs:range rdf:resource="#FlightRoute"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#fliesIn">
    <rdfs:domain rdf:resource="#FlightRoute"/>
    <rdfs:range rdf:resource="#Airspace"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasPassenger">
    <rdfs:domain rdf:resource="#Mission"/>
    <rdfs:range rdf:resource="#Passenger"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasPilot">
    <rdfs:domain rdf:resource="#Mission"/>
    <rdfs:range rdf:resource="#Pilot"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasWeather">
    <rdfs:domain rdf:resource="#Airspace"/>
    <rdfs:range rdf:resource="#WeatherCondition"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasEnergy">
    <rdfs:domain rdf:resource="#Aircraft"/>
    <rdfs:range rdf:resource="#EnergySystem"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#chargesAt">
    <rdfs:domain rdf:resource="#Aircraft"/>
    <rdfs:range rdf:resource="#ChargingStation"/>
</owl:ObjectProperty>

<!-- ===================== -->
<!-- DATA PROPERTIES -->
<!-- ===================== -->

<owl:DatatypeProperty rdf:about="#rangeKm">
    <rdfs:domain rdf:resource="#Aircraft"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#capacity">
    <rdfs:domain rdf:resource="#Aircraft"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#distanceKm">
    <rdfs:domain rdf:resource="#FlightRoute"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<owl:DatatypeProperty rdf:about="#windSpeed">
    <rdfs:domain rdf:resource="#WeatherCondition"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
</owl:DatatypeProperty>

<!-- ===================== -->
<!-- INDIVIDUALS -->
<!-- ===================== -->

<!-- Aircraft -->
<owl:NamedIndividual rdf:about="#JobyS4">
    <rdf:type rdf:resource="#eVTOL"/>
    <rangeKm rdf:datatype="http://www.w3.org/2001/XMLSchema#float">150</rangeKm>
    <capacity rdf:datatype="http://www.w3.org/2001/XMLSchema#int">4</capacity>
</owl:NamedIndividual>

<!-- Operator -->
<owl:NamedIndividual rdf:about="#JobyOperator">
    <rdf:type rdf:resource="#Operator"/>
    <operates rdf:resource="#JobyS4"/>
</owl:NamedIndividual>

<!-- Infrastructure -->
<owl:NamedIndividual rdf:about="#VertiportA">
    <rdf:type rdf:resource="#Vertiport"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#VertiportB">
    <rdf:type rdf:resource="#Vertiport"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Charging1">
    <rdf:type rdf:resource="#ChargingStation"/>
</owl:NamedIndividual>

<!-- Route -->
<owl:NamedIndividual rdf:about="#RouteA">
    <rdf:type rdf:resource="#FlightRoute"/>
    <distanceKm rdf:datatype="http://www.w3.org/2001/XMLSchema#float">40</distanceKm>
</owl:NamedIndividual>

<!-- Airspace -->
<owl:NamedIndividual rdf:about="#UrbanZone1">
    <rdf:type rdf:resource="#UrbanAirspace"/>
</owl:NamedIndividual>

<!-- Weather -->
<owl:NamedIndividual rdf:about="#Weather1">
    <rdf:type rdf:resource="#WeatherCondition"/>
    <windSpeed rdf:datatype="http://www.w3.org/2001/XMLSchema#float">10</windSpeed>
</owl:NamedIndividual>

<!-- Agents -->
<owl:NamedIndividual rdf:about="#Passenger1">
    <rdf:type rdf:resource="#Passenger"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Pilot1">
    <rdf:type rdf:resource="#Pilot"/>
</owl:NamedIndividual>

<!-- Energy -->
<owl:NamedIndividual rdf:about="#Battery1">
    <rdf:type rdf:resource="#BatterySystem"/>
</owl:NamedIndividual>

<!-- Mission -->
<owl:NamedIndividual rdf:about="#FlightMission1">
    <rdf:type rdf:resource="#FlightOperation"/>
    <hasDeparture rdf:resource="#VertiportA"/>
    <hasArrival rdf:resource="#VertiportB"/>
    <usesRoute rdf:resource="#RouteA"/>
    <hasPassenger rdf:resource="#Passenger1"/>
    <hasPilot rdf:resource="#Pilot1"/>
</owl:NamedIndividual>

<!-- ===================== -->
<!-- RELATIONSHIPS -->
<!-- ===================== -->

<owl:NamedIndividual rdf:about="#JobyS4">
    <assignedTo rdf:resource="#FlightMission1"/>
    <hasEnergy rdf:resource="#Battery1"/>
    <chargesAt rdf:resource="#Charging1"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#RouteA">
    <fliesIn rdf:resource="#UrbanZone1"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#UrbanZone1">
    <hasWeather rdf:resource="#Weather1"/>
</owl:NamedIndividual>

</rdf:RDF>